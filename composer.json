{
    "name": "antronin-consulting/psw-expiration-bundle",
    "description": "The bundle provides a solution to make a password expiration policy and a pre-expiration warning for the users.",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "symfony/config": "^8.0.8",
        "symfony/dependency-injection": "^8.0.8",
        "symfony/yaml": "^7.4|^8.0",
        "symfony/flex": "^2.10",
        "symfony/twig-bundle": "^8.0",
        "symfony/framework-bundle": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/dotenv": "^7.4",
        "symfony/runtime": "^7.4",
        "php-cs-fixer/shim": "^3.95",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/css-selector": "^7.4",
        "symfony/browser-kit": "^7.4"
    },
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "AntroninConsulting\\PswExpirationBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AntroninConsulting\\PswExpirationBundle\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Péter Nagy",
            "email": "peter@antronin.consulting"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "test": "XDEBUG_MODE=coverage vendor/bin/phpunit",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "extra": {
        "symfony": {
            "endpoint": ["https://api.github.com/repos/Antronin-Consulting/symfony-recipes/contents/index.json", "flex://defaults"],
            "allow-contrib": true
        }
    }
}
